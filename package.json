{
  "name": "@intelligent-farming/ttn-to-chirpstack",
  "version": "0.1.0",
  "description": "Translate TheThingsNetwork lorawan-devices entries into ChirpStack device profiles.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./data/browser-catalog.json": "./data/browser-catalog.json"
  },
  "license": "MIT",
  "files": ["dist/", "data/", "scripts/fetch-devices.js"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/fetch-devices.js",
    "prepare": "npm run build-browser-catalog && npm run build",
    "build-browser-catalog": "node scripts/build-browser-catalog.js",
    "update-devices": "git submodule update --remote lorawan-devices",
    "test": "npm run build && node --test --test-reporter=spec test/smoke.js test/browser-smoke.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "tar": "^6.2.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tar": "^6.1.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
